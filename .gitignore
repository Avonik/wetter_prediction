# --- Data layer (raw cache + curated tables + DuckDB) ---
# Ignore the repo-root data/ cache (NOT src/wetter/data or tests/data), but SHIP the
# small trained model artifacts so a fresh clone can serve immediately. git can't
# un-ignore a file whose parent dir is fully excluded, so ignore the *contents*
# (/data/*) and re-include the models dir + the .joblib files.
/data/*
!/data/models/
/data/models/*
!/data/models/*.joblib
*.duckdb
*.duckdb.wal

# --- Generated evaluation artifacts ---
/reports/
# report figures live under /reports/; keep *.png broad to also drop stray screenshots,
# but do NOT ignore *.html — that would swallow the website's src/wetter/web/static/index.html
*.png

# --- Browser screenshots / Playwright scratch ---
.playwright-mcp/
/luneburg-weather*.png

# --- Secrets / local config ---
.env
.env.local

# --- OS ---
.DS_Store
Thumbs.db
